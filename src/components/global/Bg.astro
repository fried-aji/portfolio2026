---
const circleData = [
  {
    pc: {
      src: 'img_circle-blue01.svg',
      width: '1028',
      height: '1028',
    },
    sp: {
      src: 'img_circle-blue01_sp.svg',
      width: '610',
      height: '610',
    },
  },
  {
    pc: {
      src: 'img_circle-blue02.svg',
      width: '920',
      height: '920',
    },
    sp: {
      src: 'img_circle-blue02_sp.svg',
      width: '720',
      height: '720',
    },
  },
  {
    pc: {
      src: 'img_circle-pink01.svg',
      width: '829',
      height: '829',
    },
    sp: {
      src: 'img_circle-pink01_sp.svg',
      width: '500',
      height: '500',
    },
  },
  {
    pc: {
      src: 'img_circle-blue03.svg',
      width: '1080',
      height: '1080',
    },
    sp: {
      src: 'img_circle-blue03_sp.svg',
      width: '717',
      height: '717',
    },
  },
  {
    pc: {
      src: 'img_circle-pink02.svg',
      width: '1085',
      height: '1085',
    },
    sp: {
      src: 'img_circle-pink02_sp.svg',
      width: '741',
      height: '741',
    },
  },
];
---

<div class="l-bg">
  <div class="base">
    <picture class="upper">
      <source media="(width >= 768px)" srcset="/img/global/img_bg-upper.svg" width="1280" height="397" />
      <img src="/img/global/img_bg-upper_sp.svg" alt="" width="1280" height="397" />
    </picture>
    <picture class="lower">
      <source media="(width >= 768px)" srcset="/img/global/img_bg-lower.svg" width="1280" height="674" />
      <img src="/img/global/img_bg-lower_sp.svg" alt="" width="1280" height="674" />
    </picture>
  </div>
  <div class="anime">
    {
      circleData.map((item) => (
        <picture class="circle">
          <source
            media="(width >= 768px)"
            srcset={`/img/global/${item.pc.src}`}
            width={item.pc.width}
            height={item.pc.height}
          />
          <img src={`/img/global/${item.sp.src}`} alt="" width={item.sp.width} height={item.sp.height} />
        </picture>
      ))
    }
  </div>
</div>

<style>
  @import '@/styles/_mql.css';

  .l-bg {
    position: relative;
    z-index: -2;
    pointer-events: none;
  }

  .base {
    position: fixed;
    top: 0;
    left: 0;
    display: grid;
    grid-template-areas: 'item';
    width: 100%;
    height: max-content;
    min-height: 100%;

    img {
      width: 100%;
    }
  }

  .lower {
    align-self: flex-end;
  }

  .anime {
    position: fixed;
    inset: 0 0 0 auto;
    display: grid;
    grid-template-areas: 'circle';
    place-items: center;
    height: max-content;

    @media (--mql-md) {
      inset: 0;
      margin: auto;
    }
  }

  .circle {
    grid-area: circle;
    animation: rotation 100s linear infinite var(--_anime-dir, normal);

    &:first-of-type {
      --_w: 610;

      @media (--mql-md) {
        --_w: 1028;
      }
    }

    &:nth-of-type(2) {
      --_w: 720;

      @media (--mql-md) {
        --_w: 920;
      }
    }

    &:nth-of-type(3) {
      --_w: 500;
      --_anime-dir: reverse;

      @media (--mql-md) {
        --_w: 829;
      }
    }

    &:nth-of-type(4) {
      --_w: 717;

      @media (--mql-md) {
        --_w: 1080;
      }
    }

    &:nth-of-type(5) {
      --_w: 741;
      --_anime-dir: reverse;

      @media (--mql-md) {
        --_w: 1085;
      }
    }

    img {
      width: calc(var(--_w) * var(--px));
      max-width: unset;
    }
  }
</style>
