<dialog
  x-data="sound"
  x-ref="dialog"
  x-bind="bindDialog"
  aria-label="サウンド切り替え"
  data-lenis-prevent
  data-toggle="open"
  class:list={[
    //
    'l-sound',
  ]}
>
  <div class="body">
    <h2 class="title">サウンドをONにしますか？</h2>
    <p class="desc">※選択後もコンフィグページから変更可能です。</p>
    <div class="control">
      <button x-bind="bindButton(false)" type="button" class="button">
        <span class="button-text">はい</span>
      </button>
      <button x-bind="bindButton(true)" type="button" class="button">
        <span class="button-text">いいえ</span>
      </button>
    </div>
  </div>
  <div class="bg">
    <Image src={ImageMenu} densities={[1, 2]} alt="" width={1280} height={720} />
  </div>
</dialog>
<div aria-hidden="true" class="u-sr-only">
  {/* eslint-disable astro/jsx-a11y/media-has-caption */}
  <audio id="sound-bgm" src="/audio/audio_bgm.mp3" loop></audio>
  <audio id="sound-effect-select" src="/audio/audio_select.mp3"></audio>
  <audio id="sound-effect-decide" src="/audio/audio_decide.mp3"></audio>
</div>

<style>
  @import '@/styles/_mql.css';

  .l-sound {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    color: var(--color-pure-white);
    transition: opacity 0.4s var(--ease-out-cubic);

    &[data-toggle='close'] {
      opacity: 0;
    }

    .body {
      padding: calc(20 * var(--px));
      text-align: center;
      opacity: 0;
      animation: fade-up 0.3s var(--ease-out-cubic) 0.3s forwards;

      @media (--mql-md) {
        padding: calc(40 * var(--px));
      }
    }

    .title {
      font-family: var(--font-dela-gothic);
      font-size: calc(20 * var(--rem));

      @media (--mql-md) {
        font-size: calc(24 * var(--rem));
      }
    }

    .desc {
      margin-top: calc(10 * var(--px));
      font-size: calc(12 * var(--rem));
      font-weight: 500;

      @media (--mql-md) {
        margin-top: calc(12 * var(--px));
        font-size: calc(14 * var(--rem));
      }
    }

    .control {
      display: grid;
      grid-template-columns: repeat(2, calc(140 * var(--px)));
      column-gap: calc(32 * var(--px));
      justify-content: center;
      margin-top: calc(36 * var(--px));

      @media (--mql-md) {
        column-gap: calc(48 * var(--px));
        margin-top: calc(40 * var(--px));
      }
    }

    .button {
      --_clip: calc(7 / 80 * 100%);
      --_clip-path: polygon(var(--_clip) 0%, 100% 0%, calc(100% - var(--_clip)) 100%, 0% 100%);

      position: relative;
      padding: calc(6 * var(--px)) calc(16 * var(--px));
      font-family: var(--font-dela-gothic);
      font-size: calc(16 * var(--rem));
      color: var(--color-black);

      @media (--mql-md) {
        --_clip: calc(12 / 140 * 100%);
      }

      &:focus-visible {
        outline: unset;
      }

      @media (any-hover: hover) {
        &:hover {
          &::after {
            background-color: var(--color-golden-yellow);
          }
        }
      }

      &::before,
      &::after {
        position: absolute;
        width: 100%;
        height: 100%;
        pointer-events: none;
        content: '';
        clip-path: var(--_clip-path);
      }

      &::after {
        inset: 0;
        background-color: var(--color-sub-pink);
      }

      &::before {
        top: calc(2 * var(--px));
        right: calc(-2 * var(--px));
        background-color: var(--color-black);

        @media (--mql-md) {
          top: calc(4 * var(--px));
          right: calc(-4 * var(--px));
        }
      }
    }

    .button-text {
      position: relative;
      z-index: 1;
    }

    .bg {
      position: fixed;
      inset: 0;
      z-index: -1;
      width: 100%;
      height: 100%;

      img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      &::before,
      &::after {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        content: '';
      }

      &::before {
        background-color: color-mix(in sRGB, var(--color-lynch) 30%, transparent 70%);
        backdrop-filter: blur(6px);
      }

      &::after {
        --_size: 1px;
        --_gap: 2px;

        background-image: radial-gradient(
          circle,
          var(--color-sub-blue) calc(var(--_size) / 2),
          transparent calc(var(--_size) / 2)
        );
        background-position: 0 0;
        background-size: calc(var(--_size) + var(--_gap)) calc(var(--_size) + var(--_gap));
      }
    }
  }
</style>
