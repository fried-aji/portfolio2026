---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import ImageMenu from '@/assets/global/img_menu.jpg';
import AstroLink from '@/components/helper/AstroLink.astro';
import MenuToggle from '@/components/ui/MenuToggle.astro';
import Calendar from '@/components/ui/Calendar.astro';
import siteNav from '@/data/siteNav';
import snsNav from '@/data/snsNav';

interface Props {
  class?: string;
}

const {
  //
  class: className,
  ...props
} = Astro.props;
---

<header
  id="header"
  class:list={[
    //
    'l-header',
  ]}
>
  <nav
    x-data="globalMenu"
    aria-label="グローバルナビゲーション"
    class:list={//
    'nav'}
  >
    <MenuToggle title="全てのメニューを開く" x-bind="bindOpen" aria-expanded="false" class="open" />
    <dialog
      x-bind="bindDialog"
      data-lenis-prevent
      aria-label="全てのメニュー"
      class:list={[
        //
        'menu',
      ]}
    >
      <MenuToggle title="全てのメニューを閉じる" x-bind="bindClose" aria-expanded="false" class="close" />
      <Calendar class="calendar" />
      <div class="outer">
        <ul class="upper">
          {
            siteNav.map((item) => (
              <li class="upper-item">
                <AstroLink href={item.href.url} target={item.href.target ?? undefined} class="upper-link">
                  {item.title.en}
                </AstroLink>
              </li>
            ))
          }
        </ul>
        <div class="lower">
          <div class="sns">
            {
              snsNav.map((item) => (
                <AstroLink href={item.href} target="_blank" class="sns-link">
                  <Icon name={`icon_${item.id}`} class="sns-logo" />
                </AstroLink>
              ))
            }
          </div>
          <AstroLink href="/" class="home">
            <Icon name="logo_site" role="img" aria-label="ホームに戻る" width={300} height={60} class="home-logo" />
          </AstroLink>
        </div>
      </div>
      <div class="bg">
        <Image src={ImageMenu} densities={[1, 2]} alt="" width={1280} height={720} />
      </div>
    </dialog>
  </nav>
</header>

<style>
  @import '@/styles/_mql.css';

  .l-header {
    position: fixed;
    top: 0;
    left: 0;
    z-index: var(--z-header);
    width: 100%;

    :global(.open) {
      margin-left: auto;

      @media (any-hover: hover) {
        &:hover {
          color: var(--color-black);
          background-color: var(--color-golden-yellow);
        }
      }
    }
  }

  .menu {
    width: 100%;
    height: 100%;
    overflow-y: auto;
    overscroll-behavior: contain;
    color: var(--color-pure-white);
    transition: opacity 0.2s var(--ease-out-cubic);

    &[data-toggle='close'] {
      opacity: 0;
    }

    :global(.close) {
      --_toggle-color: var(--color-black);
      --_toggle-bg: var(--color-pure-white);

      position: fixed;
      top: 0;
      right: 0;

      @media (any-hover: hover) {
        &:hover {
          background-color: var(--color-golden-yellow);
        }
      }
    }

    :global(.calendar) {
      --_top: 12;
      --_left: 12;

      position: absolute;
      top: calc(var(--_top) * var(--px));
      left: calc(var(--_left) * var(--px));

      @media (--mql-md) {
        --_top: 16;
        --_left: 16;
      }
    }
  }

  .bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    width: 100%;
    height: 100%;

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    &::before,
    &::after {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      content: '';
    }

    &::before {
      background-color: color-mix(in sRGB, var(--color-lynch) 30%, transparent 70%);
      backdrop-filter: blur(6px);
    }

    &::after {
      --_size: 1px;
      --_gap: 2px;

      background-image: radial-gradient(
        circle,
        var(--color-sub-blue) calc(var(--_size) / 2),
        transparent calc(var(--_size) / 2)
      );
      background-position: 0 0;
      background-size: calc(var(--_size) + var(--_gap)) calc(var(--_size) + var(--_gap));
    }
  }

  .outer {
    display: grid;
    grid-template-rows: auto 1fr;
    min-height: calc(100% + 1px);
    padding: calc(120 * var(--px)) calc(20 * var(--px)) calc(48 * var(--px));

    @media (--mql-md) {
      row-gap: calc(80 * var(--px));
      padding: calc(160 * var(--px)) calc(40 * var(--px)) calc(42 * var(--px));
    }
  }

  .upper {
    display: grid;
    gap: calc(42 * var(--px));
    width: max-content;
    margin-right: calc(12 * var(--px));
    margin-left: calc(12 * var(--px));

    @media (--mql-md) {
      grid-template-columns: repeat(2, 1fr);
      gap: calc(80 * var(--px)) calc(120 * var(--px));
      margin-right: calc(40 * var(--px));
      margin-left: calc(40 * var(--px));
    }
  }

  .upper-link {
    display: block;
    font-family: var(--font-zen-dots);
    font-size: calc(28 * var(--rem));
    line-height: 1;

    @media (--mql-md) {
      font-size: calc(48 * var(--rem));
    }

    @media (any-hover: hover) {
      &:hover {
        color: var(--color-golden-yellow);
      }
    }
  }

  .lower {
    display: grid;
    grid-template-columns: 1fr max-content;
    column-gap: calc(24 * var(--px));
    align-items: flex-end;
    align-self: flex-end;
    margin-top: calc(120 * var(--px));

    @media (--mql-md) {
      margin-top: 0;
    }
  }

  .sns {
    --_gap: 10;

    display: flex;
    column-gap: calc(var(--_gap) * var(--px));
    height: fit-content;

    @media (--mql-md) {
      --_gap: 16;
    }
  }

  .sns-link {
    --_w: 34;
    --_clip-offset: calc((1 - 10 / 40) * 100%);
    --_clip-path: polygon(0 0, 100% 0, 100% var(--_clip-offset), var(--_clip-offset) 100%, 0 100%);
    --_bg-color: var(--color-pure-white);
    --_border-offset: 2px;
    --_border-color: var(--color-lynch);
    --_border: drop-shadow(calc(var(--_border-offset) * -1) var(--_border-offset) 0 var(--_border-color))
      drop-shadow(var(--_border-offset) calc(var(--_border-offset) * -1) 0 var(--_border-color))
      drop-shadow(calc(var(--_border-offset) * -1) calc(var(--_border-offset) * -1) 0 var(--_border-color))
      drop-shadow(var(--_border-offset) var(--_border-offset) 0 var(--_border-color));

    position: relative;
    display: grid;
    place-items: center;
    width: calc(var(--_w) * var(--px));
    aspect-ratio: 1;
    filter: var(--_border);
    clip-path: var(--_clip-path);

    @media (--mql-md) {
      --_w: 40;
    }

    @media (any-hover: hover) {
      &:hover {
        --_bg-color: var(--color-golden-yellow);
      }
    }

    &::before {
      position: absolute;
      inset: 0;
      width: calc(100% - var(--_border-offset));
      aspect-ratio: 1;
      margin: auto;
      pointer-events: none;
      content: '';
      background-color: var(--_bg-color);
      clip-path: var(--_clip-path);
    }
  }

  .sns-logo {
    position: relative;
    z-index: 1;
    width: 50%;
  }

  .home {
    --_w: 181;

    width: calc(var(--_w) * var(--px));

    @media (--mql-md) {
      --_w: 320;
    }

    svg {
      width: 100%;
    }
  }
</style>
