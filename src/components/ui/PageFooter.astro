---
import AstroLink from '@/components/helper/AstroLink.astro';

interface Props {
  class?: string;
  description: string;
  nav?: {
    text: string;
    href: string;
    target?: string;
  }[];
}

const {
  //
  class: className,
  description,
  nav,
  ...props
} = Astro.props;
---

<footer
  class:list={[
    //
    'c-page-footer',
    className,
  ]}
>
  <p class="desc" set:html={description} />
  {
    nav?.map((item) => (
      <AstroLink href={item.href} target={item.target ?? undefined} class="link">
        <span class="link-text">{item.text}</span>
      </AstroLink>
    ))
  }
</footer>

<style>
  @import '@/styles/_mql.css';

  .c-page-footer {
    position: sticky;
    bottom: 0;
    z-index: calc(var(--z-header) - 1);
    display: grid;
    grid-template-areas: 'link-1 desc link-2';
    grid-template-columns: calc(80 * var(--px)) 1fr calc(80 * var(--px));
    align-items: center;

    @media (--mql-md) {
      display: block;
      background-color: var(--color-neon-blue);
    }

    &::after {
      @media (--mql-md) {
        --_size: calc(4 * var(--px));
        --_gap: calc(10 * var(--px));

        position: absolute;
        inset: 0;
        z-index: -1;
        width: 100%;
        height: 100%;
        pointer-events: none;
        content: '';
        background-image: radial-gradient(
          circle,
          var(--color-electro-nlue) calc(var(--_size) / 2),
          transparent calc(var(--_size) / 2)
        );
        background-position: 0 0;
        background-size: calc(var(--_size) + var(--_gap)) calc(var(--_size) + var(--_gap));
        opacity: 0.6;
      }
    }
  }

  .desc {
    --_clip: calc(8 / 240 * 100%);

    grid-area: desc;
    width: calc(240 * var(--px));
    padding: calc(6 * var(--px)) calc(12 * var(--px));
    margin-right: auto;
    margin-left: auto;
    font-size: calc(8 * var(--rem));
    font-weight: 500;
    text-align: center;
    background-color: var(--color-pure-white);
    clip-path: polygon(var(--_clip) 0%, 100% 0%, calc(100% - var(--_clip)) 100%, 0% 100%);

    @media (--mql-md) {
      --_clip: calc(20 / 600 * 100%);

      width: calc(600 * var(--px));
      padding: calc(10 * var(--px)) calc(16 * var(--px)) calc(12 * var(--px));
      font-size: calc(12 * var(--rem));
    }
  }

  .link {
    --_w: 80;
    --_clip: calc(7 / 80 * 100%);
    --_clip-path: polygon(var(--_clip) 0%, 100% 0%, calc(100% - var(--_clip)) 100%, 0% 100%);

    position: relative;
    display: grid;
    place-items: center;
    width: calc(var(--_w) * var(--px));
    padding: calc(4 * var(--px)) calc(8 * var(--px));
    font-family: var(--font-dela-gothic);
    font-size: calc(8 * var(--rem));

    @media (--mql-md) {
      --_w: 140;
      --_clip: calc(12 / 140 * 100%);

      position: absolute;
      top: calc(-12 * var(--px));
      padding: calc(8 * var(--px)) calc(16 * var(--px));
      font-size: calc(13 * var(--rem));
    }

    @media (any-hover: hover) {
      &:hover {
        &::after {
          background-color: var(--color-golden-yellow);
        }
      }
    }

    &:first-of-type {
      @media (--mql-md) {
        left: calc(32 * var(--px));
      }
    }

    &:last-of-type {
      @media (--mql-md) {
        right: calc(32 * var(--px));
      }
    }

    &::before,
    &::after {
      position: absolute;
      width: 100%;
      height: 100%;
      pointer-events: none;
      content: '';
      clip-path: var(--_clip-path);
    }

    &::after {
      inset: 0;
      background-color: var(--color-rose-pink);
    }

    &::before {
      background-color: var(--color-black);

      @media (--mql-md) {
        top: calc(4 * var(--px));
        right: calc(-4 * var(--px));
      }
    }
  }

  .link-text {
    position: relative;
    z-index: 1;
  }
</style>
