---
interface Props {
  class?: string;
}

const {
  //
  class: className,
  ...props
} = Astro.props;
---

<time
  datetime="2026-02-20 12:00:00"
  class:list={[
    //
    className,
  ]}
>
  <span class="upper">
    <span class="meridiem">AM</span>
    <span class="time">
      <span class="hour">12:00</span>
      <span class="sec">.00</span>
    </span>
  </span>
  <span class="lower">
    <span class="date">02.20</span>
    <span class="week">Fri</span>
  </span>
</time>
