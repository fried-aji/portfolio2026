---
interface Props {
  class?: string;
}

const {
  //
  class: className,
  ...props
} = Astro.props;
---

<small
  translate="no"
  class:list={[
    //
    'c-copyright',
    className,
  ]}
  {...props}
>
  © 2026 Riku Naganoma
</small>

<style>
  @import '@/styles/_mql.css';

  .c-copyright {
    display: block;
    font-family: var(--font-zen-dots);
    font-size: calc(10 * var(--rem));
    line-height: 1;
    color: var(--color-lynch);

    @media (--mql-md) {
      font-size: calc(12 * var(--rem));
    }
  }
</style>
