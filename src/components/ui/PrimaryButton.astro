---
import AstroLink from '@/components/helper/AstroLink.astro';

interface Props {
  class?: string;
  tag?: 'a' | 'button';
  href?: string;
  target?: string;
  text: string;
}

const {
  //
  class: className,
  tag = 'a',
  href,
  text,
  ...props
} = Astro.props;
---

{
  tag === 'a' && (
    <AstroLink class:list={['c-primary-button', className]} href={href as string} {...props}>
      <span class="text" set:html={text} />
    </AstroLink>
  )
}
{
  tag === 'button' && (
    <button class:list={['c-primary-button', className]} {...props}>
      <span class="text" set:html={text} />
    </button>
  )
}

<style>
  @import '@/styles/_mql.css';

  .c-primary-button {
    --_clip: calc(7 / 80 * 100%);
    --_clip-path: polygon(var(--_clip) 0%, 100% 0%, calc(100% - var(--_clip)) 100%, 0% 100%);

    position: relative;
    display: grid;
    font-family: var(--font-dela-gothic);
    color: var(--color-black);

    @media (--mql-md) {
      --_clip: calc(12 / 140 * 100%);
    }

    @media (any-hover: hover) {
      &:hover {
        &::after {
          background-color: var(--color-golden-yellow);
        }
      }
    }

    &::before,
    &::after {
      position: absolute;
      width: 100%;
      height: 100%;
      pointer-events: none;
      content: '';
      clip-path: var(--_clip-path);
    }

    &::after {
      inset: 0;
      background-color: var(--color-sub-pink);
    }

    &::before {
      top: calc(2 * var(--px));
      right: calc(-2 * var(--px));
      background-color: var(--color-black);

      @media (--mql-md) {
        top: calc(4 * var(--px));
        right: calc(-4 * var(--px));
      }
    }
  }

  .text {
    position: relative;
    z-index: 1;
  }
</style>
