---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import ImageVi from '@/assets/global/img_vi.png';
import Layout from '@/layouts/Layout.astro';
import SplitText from '@/components/helper/SplitText.astro';
import AstroLink from '@/components/helper/AstroLink.astro';
import Calendar from '@/components/ui/Calendar.astro';
import Copyright from '@/components/ui/Copyright.astro';
import siteNav from '@/data/siteNav';
---

<Layout>
  <main x-data="home" x-bind="bindMagnetMouse" class="p-home">
    <div class="container">
      <h1 x-ref="title" class="title">
        <Icon
          name="logo_site"
          role="img"
          aria-label="ポートフォリオ バージョン2.0"
          width={320}
          height={71}
          class="title-logo"
        />
      </h1>
      <div x-ref="vi" class="vi">
        <Image x-ref="viImage" src={ImageVi} alt="" />
        <div x-ref="viTransitionMd" class="vi-transition" data-type="md">
          {Array.from({ length: 12 }).map((_, index) => <div data-line />)}
        </div>
        <div x-ref="viTransitionSm" class="vi-transition" data-type="sm">
          {Array.from({ length: 16 }).map((_, index) => <div data-line />)}
        </div>
      </div>
      <ul class="list">
        {
          siteNav.map((item, index) => (
            <li data-item class="item">
              <AstroLink
                href={item.href.url}
                target={item.href.target ?? undefined}
                class:list={[
                  //
                  'link',
                ]}
              >
                <Icon
                  name={`icon_${item.icon.id}`}
                  role="img"
                  aria-hidden="true"
                  width={36}
                  height={36}
                  class="link-icon"
                />
                <span class="link-text">
                  <span class="link-ja">
                    <span class="u-sr-only">{item.title.ja}</span>
                    <SplitText text={item.title.ja} aria-hidden="true" class="link-split" />
                  </span>
                  <span aria-hidden="true" class="link-en">
                    <SplitText text={item.title.en} class="link-split" />
                  </span>
                </span>
              </AstroLink>
            </li>
          ))
        }
      </ul>
    </div>
    <Calendar id="home-calendar" class="calendar" />
    <Copyright x-ref="copyright" class="copyright" />
  </main>
</Layout>

<style>
  @import '@/styles/_mql.css';

  .p-home {
    position: relative;
    display: grid;
    padding-top: calc(90 * var(--px));
    padding-bottom: calc(16 * var(--px));

    @media (--mql-md) {
      padding-top: 0;
      padding-bottom: 0;
    }

    :global(.calendar) {
      position: absolute;
      top: calc(12 * var(--px));
      left: calc(12 * var(--px));

      @media (--mql-md) {
        top: calc(16 * var(--px));
        left: calc(16 * var(--px));
      }
    }

    :global(.copyright) {
      margin-top: calc(64 * var(--px));
      margin-right: calc(16 * var(--px));
      margin-left: auto;

      @media (--mql-md) {
        position: absolute;
        right: calc(24 * var(--px));
        bottom: calc(24 * var(--px));
        margin-top: 0;
        margin-right: 0;
        margin-left: 0;
      }
    }
  }

  .container {
    position: relative;

    @media (--mql-md) {
      align-self: center;
      height: calc(720 * var(--px));
    }
  }

  .title {
    width: calc(300 * var(--px));
    margin-right: calc(20 * var(--px));
    margin-left: auto;

    @media (--mql-md) {
      position: absolute;
      bottom: calc(24 * var(--px));
      left: calc(24 * var(--px));
      width: calc(320 * var(--px));
      margin-right: 0;
      margin-left: 0;
    }
  }

  .title-logo {
    width: 100%;
  }

  .list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: calc(12 * var(--px));
    margin-right: calc(12 * var(--px));
    margin-left: calc(12 * var(--px));

    @media (--mql-md) {
      --_offset: (16 * var(--px));

      position: absolute;
      top: calc(196 * var(--px));
      left: 0;
      gap: calc(16 * var(--px)) 0;
      width: calc(100% + var(--_offset) * 2);
      margin-right: 0;
      margin-left: 0;
    }
  }

  .item {
    position: relative;
    display: grid;

    @media (--mql-md) {
      rotate: -12deg;
    }

    &:nth-of-type(odd) {
      @media (--mql-md) {
        translate: calc(var(--_offset) * -1) 0;
      }
    }

    &:nth-of-type(even) {
      @media (--mql-md) {
        top: calc(22 * var(--px));
        translate: var(--_offset) 0;
      }

      .link {
        @media (--mql-md) {
          padding-left: calc(302 * var(--px));
        }
      }
    }

    @media (scripting: enabled) {
      &[data-show] {
        .link-split {
          translate: 0 0;
        }
      }
    }
  }

  .link {
    display: grid;
    grid-template-columns: max-content 1fr;
    column-gap: calc(10 * var(--px));
    align-items: center;
    padding: calc(12 * var(--px)) calc(16 * var(--px));
    color: var(--color-main);
    background-color: var(--color-sub);

    @media (--mql-md) {
      column-gap: calc(16 * var(--px));
      padding: calc(8 * var(--px)) calc(78 * var(--px));
    }

    @media (any-hover: hover) {
      &:hover {
        color: var(--color-black);
        background-color: var(--color-golden-yellow);
      }
    }
  }

  .link-icon {
    width: calc(20 * var(--px));

    @media (--mql-md) {
      width: calc(36 * var(--px));
      transform: skewX(-12deg);
    }
  }

  .link-text {
    display: grid;
    row-gap: calc(6 * var(--px));

    @media (--mql-md) {
      transform: skewX(-12deg);
    }
  }

  .link-ja {
    overflow: hidden;
    font-family: var(--font-dela-gothic);
    font-size: calc(16 * var(--rem));
    line-height: 1;
    letter-spacing: 0.04em;

    @media (--mql-md) {
      font-size: calc(30 * var(--rem));
    }
  }

  .link-en {
    overflow: hidden;
    font-family: var(--font-zen-dots);
    font-size: calc(10 * var(--rem));
    line-height: 1;
    letter-spacing: 0.04em;

    @media (--mql-md) {
      font-size: calc(14 * var(--rem));
    }
  }

  .link-split {
    display: inline-block;
    transition: translate 0.4s var(--ease-overshoot-out-dramatic) calc(var(--index) * 0.06s);

    @media (scripting: enabled) {
      translate: 0 -100%;
    }
  }

  .vi {
    position: relative;
    z-index: 1;
    width: calc(360 * var(--px));
    margin-top: calc(16 * var(--px));
    margin-right: auto;
    margin-left: auto;
    perspective: 2000px;

    @media (--mql-md) {
      right: calc(16 * var(--px));
      width: calc(580 * var(--px));
      margin-top: 0;
    }

    img {
      --_shadow-color: color-mix(in sRGB, var(--color-main-pink) 30%, transparent 70%);

      width: 100%;
      filter: drop-shadow(calc(-20 * var(--px)) 0 0 var(--_shadow-color));
    }
  }

  .vi-transition {
    position: absolute;
    inset: 0;
    width: 100%;
    overflow: hidden;

    div {
      transform: scaleX(0) translateX(-100%);
      transform-origin: left center;

      &:nth-child(3n + 1 of div) {
        background-color: var(--color-sub-blue);
      }

      &:nth-child(3n + 2 of div) {
        background-color: var(--color-sub-pink);
      }

      &:nth-child(3n + 3 of div) {
        background-color: var(--color-sub);
      }
    }

    &[data-type='sm'] {
      /* display: none; */

      div {
        height: calc(5 * var(--px));

        &:nth-child(1 of div) {
          width: 40%;
          margin-left: calc(90 * var(--px));
        }

        &:nth-child(2 of div) {
          width: 40%;
          margin-top: calc(70 * var(--px));
          margin-left: calc(300 * var(--px));
        }

        &:nth-child(3 of div) {
          width: 70%;
          margin-top: calc(50 * var(--px));
          margin-left: calc(40 * var(--px));
        }

        &:nth-child(4 of div) {
          width: 30%;
          margin-top: calc(50 * var(--px));
          margin-left: calc(320 * var(--px));
        }

        &:nth-child(5 of div) {
          width: 50%;
          margin-top: calc(50 * var(--px));
          margin-left: calc(240 * var(--px));
        }

        &:nth-child(6 of div) {
          width: 40%;
          margin-top: calc(40 * var(--px));
          margin-left: calc(60 * var(--px));
        }

        &:nth-child(7 of div) {
          width: 70%;
          margin-top: calc(30 * var(--px));
          margin-left: calc(80 * var(--px));
        }

        &:nth-child(8 of div) {
          width: 25%;
          margin-top: calc(50 * var(--px));
          margin-left: calc(20 * var(--px));
        }

        &:nth-child(9 of div) {
          width: 35%;
          margin-top: calc(30 * var(--px));
          margin-left: calc(350 * var(--px));
        }

        &:nth-child(10 of div) {
          width: 40%;
          margin-top: calc(30 * var(--px));
          margin-left: calc(160 * var(--px));
        }

        &:nth-child(11 of div) {
          width: 45%;
          margin-top: calc(50 * var(--px));
          margin-left: calc(60 * var(--px));
        }

        &:nth-child(12 of div) {
          width: 55%;
          margin-top: calc(30 * var(--px));
          margin-left: calc(180 * var(--px));
        }

        &:nth-child(13 of div) {
          width: 40%;
          margin-top: calc(60 * var(--px));
          margin-left: calc(20 * var(--px));
        }

        &:nth-child(14 of div) {
          width: 30%;
          margin-top: calc(20 * var(--px));
          margin-left: calc(360 * var(--px));
        }

        &:nth-child(15 of div) {
          width: 20%;
          margin-top: calc(60 * var(--px));
          margin-left: calc(50 * var(--px));
        }

        &:nth-child(16 of div) {
          width: 60%;
          margin-top: calc(30 * var(--px));
          margin-left: calc(200 * var(--px));
        }
      }
    }

    &[data-type='md'] {
      div {
        &:nth-child(1 of div) {
          height: calc(10 * var(--px));
          margin-top: calc(10 * var(--px));
        }

        &:nth-child(2 of div) {
          height: calc(40 * var(--px));
          margin-top: calc(10 * var(--px));
        }

        &:nth-child(3 of div) {
          height: calc(40 * var(--px));
          margin-top: calc(15 * var(--px));
        }

        &:nth-child(4 of div) {
          height: calc(50 * var(--px));
          margin-top: calc(50 * var(--px));
        }

        &:nth-child(5 of div) {
          height: calc(20 * var(--px));
          margin-top: calc(24 * var(--px));
        }

        &:nth-child(6 of div) {
          height: calc(40 * var(--px));
          margin-top: calc(64 * var(--px));
        }

        &:nth-child(7 of div) {
          height: calc(15 * var(--px));
          margin-top: calc(50 * var(--px));
        }

        &:nth-child(8 of div) {
          height: calc(40 * var(--px));
          margin-top: calc(20 * var(--px));
        }

        &:nth-child(9 of div) {
          height: calc(15 * var(--px));
          margin-top: calc(15 * var(--px));
        }

        &:nth-child(10 of div) {
          height: calc(45 * var(--px));
          margin-top: calc(24 * var(--px));
        }

        &:nth-child(11 of div) {
          height: calc(50 * var(--px));
          margin-top: calc(40 * var(--px));
        }

        &:nth-child(12 of div) {
          height: calc(30 * var(--px));
          margin-top: calc(40 * var(--px));
        }
      }
    }
  }
</style>
