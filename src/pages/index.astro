---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import ImageVi from '@/assets/global/img_vi.png';
import Layout from '@/layouts/Layout.astro';
import AstroLink from '@/components/helper/AstroLink.astro';
import Calendar from '@/components/ui/Calendar.astro';
import Copyright from '@/components/ui/Copyright.astro';
import siteNav from '@/data/siteNav';
---

<Layout>
  <main class="p-home">
    <div class="container">
      <h1 class="title">
        <Icon
          name="logo_site"
          role="img"
          aria-label="ポートフォリオ バージョン2.0"
          width={320}
          height={71}
          class="title-logo"
        />
      </h1>
      <div class="vi">
        <Image src={ImageVi} densities={[1, 2]} alt="" width={580} height={751} />
      </div>
      <ul class="list">
        {
          siteNav.map((item) => (
            <li class="item">
              <AstroLink
                href={item.href.url}
                target={item.href.target ?? undefined}
                class:list={[
                  //
                  'link',
                ]}
              >
                <Icon
                  name={`icon_${item.icon.id}`}
                  role="img"
                  aria-hidden="true"
                  width={36}
                  height={36}
                  class="link-icon"
                />
                <span class="link-text">
                  <span class="link-ja">{item.title.ja}</span>
                  <span class="link-en">{item.title.en}</span>
                </span>
              </AstroLink>
            </li>
          ))
        }
      </ul>
    </div>
    <Calendar class="calendar" />
    <Copyright class="copyright" />
  </main>
</Layout>

<style>
  @import '@/styles/_mql.css';

  .p-home {
    position: relative;
    display: grid;
    padding-top: calc(90 / var(--_container-w) * 100cqi);
    padding-bottom: calc(16 / var(--_container-w) * 100cqi);

    @media (--mql-md) {
      padding-top: 0;
      padding-bottom: 0;
    }

    :global(.calendar) {
      --_top: 12;
      --_left: 12;

      position: absolute;
      top: calc(var(--_top) / var(--_container-w) * 100cqi);
      left: calc(var(--_left) / var(--_container-w) * 100cqi);

      @media (--mql-md) {
        --_top: 16;
        --_left: 16;
      }
    }

    :global(.copyright) {
      margin-top: calc(64 / var(--_container-w) * 100cqi);
      margin-right: calc(16 / var(--_container-w) * 100cqi);
      margin-left: auto;

      @media (--mql-md) {
        position: absolute;
        right: calc(24 / var(--_container-w) * 100cqi);
        bottom: calc(24 / var(--_container-w) * 100cqi);
        margin-top: 0;
        margin-right: 0;
        margin-left: 0;
      }
    }
  }

  .container {
    position: relative;

    @media (--mql-md) {
      align-self: center;
      height: calc(720 / var(--_container-w) * 100cqi);
    }
  }

  .title {
    --_w: 300;

    width: calc(var(--_w) / var(--_container-w) * 100cqi);
    margin-right: calc(20 / var(--_container-w) * 100cqi);
    margin-left: auto;

    @media (--mql-md) {
      --_w: 320;

      position: absolute;
      bottom: calc(24 / var(--_container-w) * 100cqi);
      left: calc(24 / var(--_container-w) * 100cqi);
      margin-right: 0;
      margin-left: 0;
    }
  }

  .title-logo {
    width: 100%;
  }

  .list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: calc(12 / var(--_container-w) * 100cqi);
    margin-right: calc(12 / var(--_container-w) * 100cqi);
    margin-left: calc(12 / var(--_container-w) * 100cqi);

    @media (--mql-md) {
      --_offset: (16 / var(--_container-w) * 100cqi);

      position: absolute;
      top: calc(196 / var(--_container-w) * 100cqi);
      left: 0;
      gap: calc(16 / var(--_container-w) * 100cqi) 0;
      width: calc(100% + var(--_offset) * 2);
      margin-right: 0;
      margin-left: 0;
    }
  }

  .item {
    position: relative;

    @media (--mql-md) {
      rotate: -12deg;
    }

    &:nth-of-type(odd) {
      @media (--mql-md) {
        translate: calc(var(--_offset) * -1) 0;
      }
    }

    &:nth-of-type(even) {
      @media (--mql-md) {
        top: calc(22 / var(--_container-w) * 100cqi);
        translate: var(--_offset) 0;
      }

      .link {
        @media (--mql-md) {
          padding-left: calc(302 / var(--_container-w) * 100cqi);
        }
      }
    }
  }

  .link {
    display: grid;
    grid-template-columns: max-content 1fr;
    column-gap: calc(10 / var(--_container-w) * 100cqi);
    align-items: center;
    padding: calc(12 / var(--_container-w) * 100cqi) calc(16 / var(--_container-w) * 100cqi);
    color: var(--color-pure-white);
    background-color: var(--color-black);

    @media (--mql-md) {
      column-gap: calc(16 / var(--_container-w) * 100cqi);
      padding: calc(8 / var(--_container-w) * 100cqi) calc(78 / var(--_container-w) * 100cqi);
    }

    @media (any-hover: hover) {
      &:hover {
        color: var(--color-black);
        background-color: var(--color-golden-yellow);
      }
    }
  }

  .link-icon {
    --_w: 20;

    width: calc(var(--_w) / var(--_container-w) * 100cqi);

    @media (--mql-md) {
      --_w: 36;

      transform: skewX(-12deg);
    }
  }

  .link-text {
    --_gap: 6;

    display: grid;
    row-gap: calc(var(--_gap) / var(--_container-w) * 100cqi);

    @media (--mql-md) {
      transform: skewX(-12deg);
    }
  }

  .link-ja {
    --_fz: 16;

    font-family: var(--font-dela-gothic);
    font-size: calc(var(--_fz) / var(--_container-w) * 100cqi);
    line-height: 1;
    letter-spacing: 0.04em;

    @media (--mql-md) {
      --_fz: 30;
    }
  }

  .link-en {
    --_fz: 10;

    font-family: var(--font-zen-dots);
    font-size: calc(var(--_fz) / var(--_container-w) * 100cqi);
    line-height: 1;
    letter-spacing: 0.04em;

    @media (--mql-md) {
      --_fz: 14;
    }
  }

  .vi {
    --_w: 360;

    position: relative;
    z-index: 1;
    width: calc(var(--_w) / var(--_container-w) * 100cqi);
    margin-top: calc(16 / var(--_container-w) * 100cqi);
    margin-right: auto;
    margin-left: auto;

    @media (--mql-md) {
      --_w: 580;

      right: calc(16 / var(--_container-w) * 100cqi);
      margin-top: 0;
    }

    img {
      width: 100%;
      filter: drop-shadow(calc(-20 / var(--_container-w) * 100cqi) 0 0 rgb(255 179 237 / 30%));
    }
  }
</style>
